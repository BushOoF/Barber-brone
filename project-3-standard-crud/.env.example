# ---------------------------------------------------------------------------
# Project 3 — standard CRUD barbershop bot. Copy to .env and fill in.
# PLACEHOLDER values only — never commit real tokens.
# ---------------------------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA-replace-with-your-bot-token

# Comma-separated Telegram numeric user IDs allowed to use the bot (the barbers).
# Find yours by messaging @userinfobot. The seed creates a Barber row per id.
ADMIN_TELEGRAM_IDS=111111111,222222222

# Postgres connection string.
# For docker-compose this points at the "db" service; for local dev use localhost.
DATABASE_URL=postgresql://barber:barber@localhost:5432/barber?schema=public

# Shop timezone (IANA name). Times are stored UTC and displayed in this zone.
SHOP_TZ=Asia/Tashkent

# How many minutes before an appointment to ping the barber.
REMINDER_LEAD_MIN=10

# development | production | test
NODE_ENV=development
