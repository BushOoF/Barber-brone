# Project 1 (monolithic) — ROOT env, read by docker-compose.yml and setup.sh.
# PLACEHOLDERS ONLY — never commit real tokens. Copy to .env and fill in.

# ---- Telegram (required) ----
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token
# CSV of admin Telegram user IDs; the first is the Main Barber.
ADMIN_TELEGRAM_IDS=11111111,22222222

# ---- Postgres (compose creates this DB) ----
POSTGRES_USER=barber
POSTGRES_PASSWORD=barber
POSTGRES_DB=barber

# ---- Shop locale ----
SHOP_TZ=Asia/Tashkent
REMINDER_LEAD_MIN=10

# ---- Bot -> AI sidecar ----
AI_REQUEST_TIMEOUT_MS=45000

# ---- AI sidecar (Whisper + Ollama) ----
# 8 GB RAM is tight with Postgres+Node+Whisper+Gemma. Drop to base/tiny or use
# a hosted Ollama if the box struggles. See docker-compose.yml for details.
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_LANGUAGE=
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=gemma4:e4b
