# ---- Bot runtime (PLACEHOLDERS ONLY — never commit real tokens) ----
NODE_ENV=development

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:replace-with-your-bot-token

# Comma-separated Telegram user IDs allowed to use the bot. The first is the Main Barber.
ADMIN_TELEGRAM_IDS=11111111,22222222

# Postgres connection. In docker-compose this points at the "postgres" service.
DATABASE_URL=postgresql://barber:barber@localhost:5432/barber?schema=public

# Shop locale
SHOP_TZ=Asia/Tashkent
REMINDER_LEAD_MIN=10

# Local Python AI sidecar (Project 1 runs it on the same box).
AI_SERVICE_URL=http://localhost:8000
AI_REQUEST_TIMEOUT_MS=45000
