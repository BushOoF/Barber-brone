# ---------------------------------------------------------------------------
# Barber voice AI sidecar — Project 1 (monolithic). Copy to .env and adjust.
# PLACEHOLDER values only — do not commit real secrets.
# ---------------------------------------------------------------------------

# HTTP port the sidecar listens on (the Node bot calls it over localhost).
PORT=8000

# --- faster-whisper (speech-to-text) ---------------------------------------
# Model size: tiny | base | small | medium | large-v3 (small is the baseline).
WHISPER_MODEL=small
# Inference device: cpu | cuda
WHISPER_DEVICE=cpu
# Compute type: int8 (cpu) | int8_float16 | float16 (gpu) | float32
WHISPER_COMPUTE=int8
# Force a language (e.g. uz, ru). Leave BLANK for auto-detect (recommended for
# Uzbek/Russian code-switching).
WHISPER_LANGUAGE=

# --- Ollama (intent extraction via Gemma) ----------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
# Per-request timeout for the Ollama call, in milliseconds.
OLLAMA_TIMEOUT_MS=60000

# --- Optional overrides ------------------------------------------------------
# Path/name of the ffmpeg binary if it is not on PATH.
# FFMPEG_BIN=ffmpeg
