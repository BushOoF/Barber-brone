generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  APPRENTICE
}

enum Lang {
  UZ
  RU
  EN
}

enum BarberRole {
  MAIN
  APPRENTICE
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED_BY_USER
  DISCARDED_NO_SHOW
  TRANSFERRED
}

enum BlockType {
  BREAK
  WALK_IN
  MANUAL
}

enum ServiceCategory {
  HAIRCUT_ADULT  // a haircut style selectable for adult party members
  HAIRCUT_CHILD  // a haircut style selectable for child party members
  ADDON          // optional extras like wash, beard
}

enum FinanceKind {
  INCOME
  EXPENSE
}

model User {
  id          String   @id @default(cuid())
  /// Nullable so an admin can pre-create a "placeholder" apprentice by phone
  /// before that person has ever opened the bot. It's filled in (linked) when
  /// they /start the bot and share the matching contact. Still unique — Postgres
  /// allows multiple NULLs under a unique constraint.
  telegramId  BigInt?  @unique
  username    String?
  firstName   String?
  lastName    String?
  phone       String?
  role        Role     @default(CUSTOMER)
  language    Lang     @default(UZ)
  remindersOn Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings        Booking[]
  barberProfile   Barber?
  sentAnnouncements Announcement[]
}

model Barber {
  id          String     @id @default(cuid())
  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        BarberRole
  isActive    Boolean    @default(true)
  displayName String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  bookings Booking[]
  blocks   TimeBlock[]
}

model Service {
  id          String          @id @default(cuid())
  key         String          @unique
  name        String
  category    ServiceCategory @default(ADDON)
  /// Exactly one Service per HAIRCUT_ADULT and HAIRCUT_CHILD category should
  /// have isDefault=true. Used as the fallback style when a customer doesn't
  /// pick one explicitly.
  isDefault   Boolean         @default(false)
  durationMin Int
  priceMinor  Int
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
}

model Booking {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  barberId       String
  barber         Barber        @relation(fields: [barberId], references: [id])
  startAt        DateTime
  endAt          DateTime
  durationMin    Int
  totalPriceMinor Int
  adults         Int           @default(1)
  children       Int           @default(0)
  services       String[]
  /// Service.key for the chosen adult haircut style; null = use the HAIRCUT_ADULT default.
  selectedAdultStyleKey String?
  /// Service.key for the chosen child haircut style; null = use the HAIRCUT_CHILD default.
  selectedChildStyleKey String?
  status         BookingStatus @default(SCHEDULED)
  remindersOn    Boolean       @default(true)
  reminderSentAt DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([barberId, startAt])
  @@index([status, startAt])
}

model TimeBlock {
  id        String    @id @default(cuid())
  barberId  String
  barber    Barber    @relation(fields: [barberId], references: [id])
  startAt   DateTime
  endAt     DateTime
  type      BlockType
  note      String?
  createdAt DateTime  @default(now())

  @@index([barberId, startAt])
}

/// Broadcast announcement made by the barber (admin) to every customer that's
/// shared their contact with the bot. One row per send; per-recipient delivery
/// status is logged but not stored individually to keep the table small.
model Announcement {
  id           String   @id @default(cuid())
  message      String
  /// Telegram file_id captured from the first sendPhoto. Reusing it for every
  /// subsequent recipient avoids re-uploading the bytes to Telegram for each
  /// customer. Null when the announcement was text-only.
  photoFileId  String?
  /// Original filename of the uploaded image — for display in history.
  photoName    String?
  sentByUserId String
  sentBy       User     @relation(fields: [sentByUserId], references: [id])
  recipients   Int      @default(0)
  delivered    Int      @default(0)
  failed       Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model Settings {
  id                   String   @id @default("singleton")
  shopName             String   @default("Barbershop")
  timezone             String   @default("Asia/Tashkent")
  currency             String   @default("UZS")
  reminderLeadMin      Int      @default(15)
  openHourMin          Int      @default(540)
  closeHourMin         Int      @default(1260)
  location             String?  // Address shown to customers on booking confirmation.
  /// GPS coordinates of the shop, captured via the bot's /location command.
  /// When present, maps links use coords (precise) instead of geocoding the
  /// text address (best-effort). Both can be set independently.
  locationLat          Float?
  locationLng          Float?
  hasApprenticeFeature Boolean  @default(true)  // Toggled remotely by the barber-dev operator bot.
  updatedAt            DateTime @updatedAt
}

/// Manual budgeting entry the admin adds in Finances — extra income (e.g. a
/// product sale) or an expense (e.g. rent, supplies). Recurring entries store a
/// `repeatEveryDays` interval; the finance summary expands them across the
/// queried range to total them automatically. Booking revenue is tracked
/// separately on Booking rows and is NOT duplicated here.
model FinanceEntry {
  id              String      @id @default(cuid())
  kind            FinanceKind
  amountMinor     Int
  note            String?
  /// First (or only) occurrence, as a "YYYY-MM-DD" date-key in the shop's TZ.
  date            String
  /// null = one-time. >0 = repeats every this-many days starting from `date`.
  repeatEveryDays Int?
  createdAt       DateTime    @default(now())

  @@index([date])
}

/// Shop-wide closure days. When today's date-key matches a row here, every
/// availability query returns empty and new bookings are rejected. Existing
/// bookings are not auto-cancelled — the barber sorts those manually.
model VacationDay {
  id        String   @id @default(cuid())
  /// "YYYY-MM-DD" in the shop's timezone (Settings.timezone, default Asia/Tashkent).
  date      String   @unique
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
}
