NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://barber:barber_dev_password@localhost:5432/barber_brone?schema=public

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_token_from_BotFather
# Comma-separated list of admin Telegram user IDs. The first ID is the Main Barber.
TELEGRAM_ADMIN_IDS=123456789
WEBAPP_URL=https://your-tunnel.ngrok-free.app
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

SHOP_TIMEZONE=Asia/Tashkent
SHOP_CURRENCY=UZS

# Comma-separated list of additional allowed CORS origins (the webapp URL is added automatically)
CORS_EXTRA_ORIGINS=http://localhost:5173
