NODE_ENV=development

# Telegram — a separate bot, distinct from any per-shop bot.
BARBER_DEV_BOT_TOKEN=replace_with_token_from_BotFather

# Comma-separated. The first ID is the "super operator" (can add/remove other operators).
# Anyone in this list can use the bot from the moment the process starts; additional
# operators added via /addop are stored in the control DB.
OPERATOR_TELEGRAM_IDS=123456789

# Operator/control database — keeps shop registry, operators, fees, revenue snapshots.
# Use a dedicated database, NOT one of the per-shop databases.
DATABASE_URL=postgresql://barber:barber_dev_password@localhost:5432/barber_control?schema=public

# Optional: send all operator notifications in this timezone (defaults to Asia/Tashkent).
TIMEZONE=Asia/Tashkent

# Optional webhook mode (production). Leave empty for long-polling.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
