# Keep the build context small and never ship local artifacts/secrets into the image.
.git
.gitignore
.dockerignore
Dockerfile
README.md

# Python caches / virtualenvs
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Secrets / local env
.env
.env.*
!.env.example

# Audio scratch & model caches (downloaded at runtime, not baked in)
*.wav
*.ogg
*.mp3
*.m4a
/tmp/
models/
.cache/
