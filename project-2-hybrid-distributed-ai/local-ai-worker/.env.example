# Local AI Worker — environment configuration.
# Copy to .env and fill in real values. PLACEHOLDERS ONLY here — never commit real secrets.

# ----------------------------------------------------------------------------- Security
# Shared secret the cloud bot must send in the X-Worker-Secret header. MUST match the cloud bot's
# WORKER_SHARED_SECRET. Minimum 8 chars; use a long random string in production, e.g.
#   openssl rand -hex 32
WORKER_SHARED_SECRET=change-me-to-a-long-random-secret

# ----------------------------------------------------------------------------- HTTP server
PORT=8000
HOST=0.0.0.0

# ----------------------------------------------------------------------------- Whisper (STT)
# faster-whisper model size. small = good Uzbek/Russian quality on a PC.
# On a Raspberry Pi 5 prefer base or tiny (see README "Pi 5 model sizes").
WHISPER_MODEL=small
# cpu (Pi / most PCs) or cuda (NVIDIA GPU)
WHISPER_DEVICE=cpu
# int8 is the fast/light default for CPU. Use int8_float16 / float16 on GPU.
WHISPER_COMPUTE=int8
# Blank = auto-detect. Set to e.g. "uz" or "ru" only if you want to force a language.
WHISPER_LANGUAGE=

# ----------------------------------------------------------------------------- Ollama (LLM)
# Where Ollama is reachable from THIS worker (same host => localhost).
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
# Generous timeout for slow CPU/ARM inference (seconds).
OLLAMA_TIMEOUT_S=120

# ----------------------------------------------------------------------------- Audio / ffmpeg
# Path or name of the ffmpeg binary (must be on PATH or absolute).
FFMPEG_BIN=ffmpeg
# Max accepted upload size in bytes (default 25 MiB).
MAX_AUDIO_BYTES=26214400

# ----------------------------------------------------------------------------- Logging
# DEBUG logs transcripts (may contain phone numbers) — keep at INFO in production.
LOG_LEVEL=INFO
