# ---- Telegram ----
# Bot token from @BotFather (PLACEHOLDER — never commit a real token).
TELEGRAM_BOT_TOKEN=123456789:AA-REPLACE-WITH-YOUR-BOT-TOKEN
# Comma-separated Telegram user IDs allowed to use the bot (the barber[s]).
ADMIN_TELEGRAM_IDS=111111111,222222222

# ---- Database ----
# Matches docker-compose.yml defaults. In docker the host is the service name "db".
DATABASE_URL=postgresql://barber:barber@db:5432/barber?schema=public
# For local dev outside docker, use localhost instead:
# DATABASE_URL=postgresql://barber:barber@localhost:5432/barber?schema=public

# ---- Shop locale ----
SHOP_TZ=Asia/Tashkent
REMINDER_LEAD_MIN=10

# ---- Remote AI worker (reached over a secure tunnel) ----
# The public HTTPS URL of the local-ai-worker's tunnel (Cloudflare/Tailscale/ngrok/SSH).
AI_SERVICE_URL=https://your-tunnel-subdomain.trycloudflare.com
# Shared secret sent as the X-Worker-Secret header. MUST match the worker's value.
# Generate with: openssl rand -hex 32
WORKER_SHARED_SECRET=replace-with-a-long-random-shared-secret
# How long to wait for the worker (STT + LLM over the tunnel can take a while).
AI_REQUEST_TIMEOUT_MS=60000

# ---- Optional: webhook mode ----
# Leave WEBHOOK_URL blank to use long-polling (recommended on a small VPS).
# To use webhooks, set a public HTTPS base URL that forwards to this container.
WEBHOOK_URL=
WEBHOOK_SECRET=
PORT=8080

# ---- Optional ----
NODE_ENV=production
# LOG_LEVEL=info   # set to "debug" to log transcripts (never logs phone numbers)
