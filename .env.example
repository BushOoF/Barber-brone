# ---- Backend ----
NODE_ENV=development
PORT=3000

# Postgres (matches docker-compose.yml defaults — change for your environment)
DATABASE_URL=postgresql://barber:barber_dev_password@localhost:5432/barber_brone?schema=public

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_token_from_BotFather
# Comma-separated list of admin Telegram user IDs. The first ID is the Main Barber.
TELEGRAM_ADMIN_IDS=123456789
# Public URL of the Mini App (set in BotFather → /setdomain and /newapp). In dev use an ngrok HTTPS URL.
WEBAPP_URL=https://your-tunnel.ngrok-free.app
# Webhook mode (production). Leave empty for long-polling in dev.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Shop locale
SHOP_TIMEZONE=Asia/Tashkent
SHOP_CURRENCY=UZS

# ---- Frontend (apps/webapp/.env) ----
# VITE_API_URL=http://localhost:3000
