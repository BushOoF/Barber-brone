# Example Nginx config for production deployment.
# Replace `barber.example.com` with your domain and `/srv/barber-brone/webapp` with where you
# copy `apps/webapp/dist`. Issue TLS certs with certbot (omitted here).

upstream barber_backend {
    server 127.0.0.1:3000;
    keepalive 16;
}

server {
    listen 80;
    server_name barber.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name barber.example.com;

    # Managed by certbot — replace paths if needed.
    ssl_certificate     /etc/letsencrypt/live/barber.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/barber.example.com/privkey.pem;

    # Mini App SPA
    root /srv/barber-brone/webapp;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-store" always;
    }

    # Static assets — long cache
    location ~* \.(js|css|woff2?|png|jpg|jpeg|svg|webp)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Backend API
    location /api/ {
        proxy_pass         http://barber_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Telegram webhook (set TELEGRAM_WEBHOOK_URL=https://barber.example.com/telegram/webhook)
    location = /telegram/webhook {
        proxy_pass         http://barber_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Healthcheck (used by PM2 / monitoring)
    location = /healthz {
        proxy_pass http://barber_backend;
        access_log off;
    }
}
